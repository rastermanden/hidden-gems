{
  "name": "hidden-gems",
  "version": "1.0.0",
  "scripts": {
    "start": "node -e \"const h=require('http'),fs=require('fs'),p=require('path'),port=process.env.PORT||3000;h.createServer((q,r)=>{let f=p.join(__dirname,q.url==='/'?'index.html':q.url);fs.readFile(f,(e,d)=>{if(e){r.writeHead(404);r.end('Not found')}else{const m={'html':'text/html','js':'text/javascript','css':'text/css'};r.writeHead(200,{'Content-Type':m[f.split('.').pop()]||'text/plain'});r.end(d)}})}).listen(port,()=>console.log('Server running at http://localhost:'+port))\""
  }
}
